<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>WinExe</OutputType>
        <TargetFramework>net48</TargetFramework>
        <RootNamespace>MakeKits.Workshop.Host</RootNamespace>
        <AssemblyName>MakeKits.Workshop.Host</AssemblyName>
        <LangVersion>preview</LangVersion>
        <Version>0.0.17.0</Version>
        <UseWPF>true</UseWPF>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
        <Platforms>AnyCPU;x64</Platforms>
    </PropertyGroup>

    <ItemGroup Condition="'$(Configuration)' == 'Debug'">
        <ProjectReference Include="..\..\src\MakeKits.Workshop.Abstractions\MakeKits.Workshop.Abstractions.csproj">
            <Project>{0D4566F1-A836-46E7-B79C-1303B30FC768}</Project>
            <Private>True</Private>
        </ProjectReference>
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="MakeKits.Workshop.Abstractions" Version="0.0.17.0" Condition=" '$(Configuration)' == 'Release'" />
        <PackageReference Include="Costura.Fody" Version="6.0.0" Condition=" '$(Configuration)' == 'Release'">
            <PrivateAssets>all</PrivateAssets>
            <IncludeAssets>compile; runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
        </PackageReference>
        <PackageReference Include="WPF-UI" Version="4.3.0" />
    </ItemGroup>

    <ItemGroup>
        <Content Include="$(NuGetPackageRoot)\microsoft.windows.console.conpty\1.24.260710001\runtimes\win-x64\native\conpty.dll" Condition="'$(TargetFramework)' == 'net472' Or '$(TargetFramework)' == 'net48' Or '$(TargetFramework)' == 'net481'">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
            <DestinationFolder>$(OutDir)\</DestinationFolder>
            <Link>conpty.dll</Link>
        </Content>
        <Content Include="$(NuGetPackageRoot)\microsoft.windows.console.conpty\1.24.260710001\build\native\runtimes\x64\OpenConsole.exe">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
            <DestinationFolder>$(OutDir)\</DestinationFolder>
            <Link>OpenConsole.exe</Link>
        </Content>
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\template\MakeKits.Workshop.Console.Default\MakeKits.Workshop.Console.Default.csproj" />
        <ProjectReference Include="..\..\template\MakeKits.Workshop.Executable.Default\MakeKits.Workshop.Executable.Default.csproj" />
        <ProjectReference Include="..\..\template\MakeKits.Workshop.Webview.Debugger\MakeKits.Workshop.Webview.Debugger.csproj" />
        <ProjectReference Include="..\..\template\MakeKits.Workshop.Webview.Default\MakeKits.Workshop.Webview.Default.csproj" />
        <ProjectReference Include="..\MakeKits.Workshop.Executable.HelloWorld\MakeKits.Workshop.Executable.HelloWorld.csproj" />
        <ProjectReference Include="..\MakeKits.Workshop.Webview.HelloWorld\MakeKits.Workshop.Webview.HelloWorld.csproj" />
        <ProjectReference Include="..\MakeKits.Workshop.WPF.HelloWorld\MakeKits.Workshop.WPF.HelloWorld.csproj" />
    </ItemGroup>

</Project>
