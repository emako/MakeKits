<Window
    x:Class="MakeKits.Workshop.Host.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="MakeKits Workshop"
    Width="1280"
    Height="720"
    Background="#F0F0F5">

    <Window.Resources>

        <!--  Card button: removes default Button chrome, adds rounded hover/press states  -->
        <Style x:Key="CardButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E2E2EC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F5F5FF" />
                                <Setter Property="BorderBrush" Value="#8888DD" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#EDEDFF" />
                                <Setter Property="BorderBrush" Value="#6666CC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Back button: transparent, white text  -->
        <Style x:Key="BackButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#CCCCDD" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="Background" Value="#33334A" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#44445A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>

        <!--
            ═══════════════════════════════════════════════
            Page 1 — Workshop card list
            ═══════════════════════════════════════════════
        -->
        <Grid x:Name="ListPage" Visibility="Visible">
            <Grid.RowDefinitions>
                <RowDefinition Height="56" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  Header bar  -->
            <Border Grid.Row="0" Background="#1A1A2E">
                <StackPanel
                    Margin="24,0,0,0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock
                        FontSize="20"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="Creative Workshop" />
                    <TextBlock
                        x:Name="WorkshopCountText"
                        Margin="10,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="#7777AA"
                        Text="" />
                </StackPanel>
            </Border>

            <!--  Card list  -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <Grid>
                    <!--  Cards  -->
                    <ItemsControl x:Name="WorkshopList" Margin="16,12,16,16">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button
                                    Width="240"
                                    Height="140"
                                    Margin="8"
                                    Click="OnWorkshopCardClick"
                                    Style="{StaticResource CardButtonStyle}"
                                    Tag="{Binding}">
                                    <Grid Margin="16,14,16,14">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!--  Name  -->
                                        <TextBlock
                                            Grid.Row="0"
                                            FontSize="15"
                                            FontWeight="Bold"
                                            Foreground="#1A1A2E"
                                            Text="{Binding Name}"
                                            TextTrimming="CharacterEllipsis" />

                                        <!--  Description  -->
                                        <TextBlock
                                            Grid.Row="1"
                                            Margin="0,6,0,0"
                                            FontSize="12"
                                            Foreground="#666677"
                                            Text="{Binding Workshop.Descriptor.Description}"
                                            TextTrimming="CharacterEllipsis"
                                            TextWrapping="Wrap" />

                                        <!--  Author / Version  -->
                                        <StackPanel
                                            Grid.Row="2"
                                            Margin="0,8,0,0"
                                            Orientation="Horizontal">
                                            <TextBlock
                                                FontSize="11"
                                                Foreground="#AAAABB"
                                                Text="{Binding Author}" />
                                            <TextBlock
                                                FontSize="11"
                                                Foreground="#CCCCDD"
                                                Text=" · " />
                                            <TextBlock
                                                FontSize="11"
                                                Foreground="#AAAABB"
                                                Text="{Binding Version}" />
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!--  Empty state  -->
                    <StackPanel
                        x:Name="EmptyStatePanel"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="Collapsed">
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="36"
                            Foreground="#CCCCDD"
                            Text="📦" />
                        <TextBlock
                            Margin="0,12,0,0"
                            HorizontalAlignment="Center"
                            FontSize="16"
                            Foreground="#9999AA"
                            Text="No Workshop available" />
                        <TextBlock
                            Margin="0,6,0,0"
                            HorizontalAlignment="Center"
                            FontSize="12"
                            Foreground="#BBBBCC"
                            Text="Please place the plugin DLL into the workshops directory and restart the application." />
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>

        <!--
            ═══════════════════════════════════════════════
            Page 2 — Workshop view
            ═══════════════════════════════════════════════
        -->
        <Grid x:Name="WorkshopPage" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  Title bar  -->
            <Border Grid.Row="0" Background="#1A1A2E">
                <DockPanel LastChildFill="True">
                    <Button
                        Click="OnBackClicked"
                        Content="← Go Back"
                        DockPanel.Dock="Left"
                        Style="{StaticResource BackButtonStyle}" />
                    <Separator
                        Width="1"
                        VerticalAlignment="Stretch"
                        Background="#33334A"
                        DockPanel.Dock="Left" />
                    <TextBlock
                        x:Name="WorkshopTitleText"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Foreground="White" />
                </DockPanel>
            </Border>

            <!--  Workshop content area  -->
            <Grid Grid.Row="1">
                <!--  Busy indicator (shown while IsBusy = true)  -->
                <Border
                    x:Name="BusyOverlay"
                    Panel.ZIndex="10"
                    Background="#80FFFFFF"
                    Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="14"
                            Foreground="#555566"
                            Text="Loading..." />
                    </StackPanel>
                </Border>

                <!--  Actual workshop content  -->
                <ContentControl x:Name="WorkshopContent" />
            </Grid>
        </Grid>

    </Grid>
</Window>
