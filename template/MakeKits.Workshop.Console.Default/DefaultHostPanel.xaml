<UserControl x:Class="MakeKits.Workshop.Console.Default.DefaultHostPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:t="http://schemas.lepo.co/wpfui/2022/xaml/terminal"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <t:ExtendedTerminalControl x:Name="basicTermControl"
                               InputCapture="TabKey,DirectionKeys"
                               LogConPTYOutput="True"
                               StartupCommandLine="{Binding StartupCommand}"
                               Theme="{Binding Theme, Mode=OneWay}"
                               Win32InputMode="True"
                               WorkingDirectory="{Binding WorkingDirectory}" />
</UserControl>
